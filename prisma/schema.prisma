generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int            @id @default(autoincrement())
  email                  String         @unique
  name                   String?
  passwordHash           String
  role                   Role
  specialization         String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  auditLogs              AuditLog[]
  consultationsAsDoctor  Consultation[] @relation("DoctorConsultations")
  consultationsAsPatient Consultation[] @relation("PatientConsultations")

  @@map("users")
}

model Consultation {
  id                 Int                @id @default(autoincrement())
  patientId          Int
  doctorId           Int?
  riskLevel          String
  language           String             @default("English")
  status             ConsultationStatus @default(PENDING)
  doctorNotes        String?            @db.LongText
  finalDiagnosis     String?            @db.LongText
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  blockchainHash     String?
  ddiAlerts          Json
  finalizedByDoctor  Boolean            @default(false)
  medicines          Json
  probableConditions Json
  structuredSymptoms Json
  summaryText        String             @db.LongText
  transcript         String             @db.LongText
  auditLogs          AuditLog[]
  blockchainRecord   BlockchainRecord?
  doctor             User?              @relation("DoctorConsultations", fields: [doctorId], references: [id])
  patient            User               @relation("PatientConsultations", fields: [patientId], references: [id], onDelete: Cascade)
  mlInferenceLog     MLInferenceLog?

  @@index([patientId, createdAt])
  @@index([doctorId, status])
  @@map("consultations")
}

model DrugInteraction {
  id          Int         @id @default(autoincrement())
  drugA       String
  drugB       String
  severity    DDISeverity
  description String      @db.LongText

  @@unique([drugA, drugB])
  @@map("drug_interactions")
}

model BlockchainRecord {
  id             Int          @id @default(autoincrement())
  consultationId Int          @unique
  patientId      Int
  dataHash       String       @unique
  txId           String       @unique
  blockNumber    Int
  timestamp      DateTime     @default(now())
  verified       Boolean      @default(true)
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("blockchain_records")
}

model MLInferenceLog {
  id             Int          @id @default(autoincrement())
  consultationId Int          @unique
  patientId      Int
  inputText      String       @db.LongText
  language       String
  modelVersion   String
  predictions    Json
  processingTime Int
  timestamp      DateTime     @default(now())
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("ml_inference_logs")
}

model AuditLog {
  id             Int           @id @default(autoincrement())
  module         String
  action         String
  userId         Int?
  resourceId     Int?
  timestamp      DateTime      @default(now())
  details        Json
  consultationId Int?
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([consultationId], map: "audit_logs_consultationId_fkey")
  @@map("audit_logs")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ConsultationStatus {
  PENDING
  REVIEWED
  COMPLETED
}

enum DDISeverity {
  MILD
  MODERATE
  SEVERE
}
