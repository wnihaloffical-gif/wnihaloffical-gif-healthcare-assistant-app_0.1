// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  name            String?
  passwordHash    String
  role            Role
  specialization  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  consultationsAsPatient  Consultation[] @relation("PatientConsultations")
  consultationsAsDoctor   Consultation[] @relation("DoctorConsultations")
  auditLogs               AuditLog[]

  @@map("users")
}

model Consultation {
  id                    Int      @id @default(autoincrement())
  patientId             Int
  doctorId              Int?
  
  symptoms              String   @db.LongText  // Array stored as JSON
  riskLevel             RiskLevel
  hasRedFlags           Boolean  @default(false)
  redFlagWarnings       String   @db.LongText  // Array stored as JSON
  language              String   @default("English")
  status                ConsultationStatus @default(PENDING)
  
  doctorNotes           String?  @db.LongText
  finalDiagnosis        String?  @db.LongText
  finalMedicines        String   @default("[]") @db.LongText  // Array stored as JSON
  patientSummaryText    String?  @db.LongText

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               User     @relation("PatientConsultations", fields: [patientId], references: [id], onDelete: Cascade)
  doctor                User?    @relation("DoctorConsultations", fields: [doctorId], references: [id], onDelete: SetNull)
  probableConditions    ProbableCondition[]
  suggestedMedicines    SuggestedMedicine[]
  ddiAlerts             DDIAlert[]
  blockchainRecord      BlockchainRecord?
  mlInferenceLog        MLInferenceLog?
  auditLogs             AuditLog[]

  @@map("consultations")
  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model ProbableCondition {
  id                Int      @id @default(autoincrement())
  consultationId    Int
  name              String
  confidence        Float
  severity          String

  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("probable_conditions")
  @@index([consultationId])
}

model SuggestedMedicine {
  id                Int      @id @default(autoincrement())
  consultationId    Int
  medicineId        String
  name              String
  dose              String
  frequency         String
  explanation       String   @db.LongText

  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("suggested_medicines")
  @@index([consultationId])
}

model DDIAlert {
  id                Int          @id @default(autoincrement())
  consultationId    Int
  drug1             String
  drug2             String
  severity          DDISeverity
  description       String       @db.LongText

  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("ddi_alerts")
  @@index([consultationId])
}

model BlockchainRecord {
  id                Int          @id @default(autoincrement())
  consultationId    Int          @unique
  patientId         Int
  dataHash          String       @unique
  txId              String       @unique
  blockNumber       Int
  timestamp         DateTime
  verified          Boolean      @default(true)

  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("blockchain_records")
  @@index([patientId])
}

model MLInferenceLog {
  id                Int      @id @default(autoincrement())
  consultationId    Int      @unique
  patientId         Int
  inputText         String   @db.LongText
  language          String
  modelVersion      String
  predictions       Json
  processingTime    Int
  timestamp         DateTime @default(now())

  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("ml_inference_logs")
  @@index([patientId])
}

model AuditLog {
  id                Int          @id @default(autoincrement())
  module            String
  action            String
  userId            Int?
  resourceId        Int?
  timestamp         DateTime @default(now())
  details           Json

  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  consultation      Consultation? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([userId])
  @@index([module])
}

// Enums
enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ConsultationStatus {
  PENDING
  REVIEWED
  COMPLETED
}

enum DDISeverity {
  MILD
  MODERATE
  SEVERE
}
